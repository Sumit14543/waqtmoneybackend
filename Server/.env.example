APP_ENV=production
NODE_ENV=production
PORT=5000

CLIENT_BASE_URL=https://waqtmoney.com
API_PUBLIC_BASE_URL=https://waqtmoney-api.onrender.com
ADMIN_BASE_URL=
CORS_ORIGINS=https://waqtmoney.com,https://www.waqtmoney.com
ALLOW_LOCAL_CORS=false

DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
ALLOW_LOCAL_DB_IN_PRODUCTION=false

JWT_SECRET=
APP_SECRET_KEY=
AUTH_KEY=

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_TLS_SERVERNAME=
SMTP_USER=
SMTP_PASS=

PAN_API_KEY=
CRM_API_KEY=
BIFROST_API_TOKEN=
BIFROST_REACT_API_TOKEN=
BIFROST_UAN_ENDPOINT=get-phone-to-uan
UAN_API_TIMEOUT_MS=5000
UAN_CACHE_TTL_MS=86400000
UAN_NEGATIVE_CACHE_TTL_MS=600000
UAN_ENABLE_LEGACY_ENDPOINT_FALLBACK=false
UAN_LOOKUP_SYNC_ON_APPLY=false
UAN_LOOKUP_BACKGROUND_ON_APPLY=true
UAN_LOOKUP_BACKGROUND_ON_UPDATE=true
UAN_LOOKUP_SYNC_ON_PAN=false
UAN_LOOKUP_BACKGROUND_ON_PAN=true
UAN_LOOKUP_DIRECT_ON_PAN=false

CASHFREE_ENV=production
CASHFREE_API_VERSION=2025-01-01
CASHFREE_API_TIMEOUT_MS=8000
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_ALLOWED_ORIGIN=https://waqtmoney.com
CASHFREE_RETURN_URL=https://waqtmoney.com/repayment/make-payment?order_id={order_id}&application_id={application_id}
CASHFREE_NOTIFY_URL=
